---
import AudienceBadge from '../components/AudienceBadge.astro';
import GmGate from '../components/GmGate.astro';
import Hero from '../components/Hero.astro';
import SpoilerBanner from '../components/SpoilerBanner.astro';
import BaseLayout from './BaseLayout.astro';

type Props = {
  title: string;
  summary: string;
  eyebrow?: string;
  audience?: 'public' | 'player' | 'gm';
  spoilerLevel?: 'none' | 'light' | 'major';
  theme?: 'public' | 'gm';
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  robots?: string;
  gmGate?: boolean;
};

const {
  title,
  summary,
  eyebrow,
  audience = 'public',
  spoilerLevel = 'none',
  theme = audience === 'gm' ? 'gm' : 'public',
  ctaPrimary,
  ctaSecondary,
  robots,
  gmGate = false,
} = Astro.props;
---

<BaseLayout title={title} description={summary} theme={theme} robots={robots}>
  <section class="page-hero">
    <AudienceBadge audience={audience} spoilerLevel={spoilerLevel} />
    {gmGate && <SpoilerBanner />}
    <Hero
      title={title}
      subtitle={summary}
      eyebrow={eyebrow}
      ctaPrimary={ctaPrimary}
      ctaSecondary={ctaSecondary}
    />
  </section>
  <div class="content-shell">
    {gmGate ? (
      <GmGate>
        <slot />
      </GmGate>
    ) : (
      <slot />
    )}
  </div>
</BaseLayout>
