---
import { mainNav, gmNav } from '../lib/navigation';

type Props = {
  theme?: 'public' | 'gm';
};

const { theme = 'public' } = Astro.props;
const isGm = theme === 'gm';
---

<footer class="site-footer">
  <div class="site-footer__grid">
    <div>
      <p class="footer-title">Ka-Tet: The Path of the Beam</p>
      <p class="footer-copy">
        Fan-made tabletop RPG and campaign resource for private play. Inspired by dark western
        fantasy, cosmic horror, broken worlds, and fate-bound heroes.
      </p>
    </div>
    <div>
      <p class="footer-title">Explore</p>
      <div class="footer-links">
        {mainNav.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </div>
    </div>
    <div>
      <p class="footer-title">{isGm ? 'GM' : 'Need a Quick Start?'}</p>
      <div class="footer-links">
        {isGm ? (
          gmNav.map((item) => <a href={item.href}>{item.label}</a>)
        ) : (
          <>
            <a href="/downloads/player-quickstart.md">Read the Quickstart</a>
            <a href="/pregens">Pick a Pre-Gen</a>
            <a href="/join-a-game">Join the Interest List</a>
          </>
        )}
      </div>
    </div>
  </div>
  <div class="site-footer__meta">
    <span>Long days and pleasant nights.</span>
    <span>Version 0.1 · Built with Astro</span>
  </div>
</footer>
