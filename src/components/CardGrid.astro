---
export type Card = {
  title: string;
  summary: string;
  href?: string;
  icon?: string;
  audience?: 'public' | 'player' | 'gm';
  spoilerLevel?: 'none' | 'light' | 'major';
  status?: 'live' | 'coming-soon';
  helperText?: string;
};

type Props = {
  cards: Card[];
};

const { cards } = Astro.props;
---

<div class="card-grid">
  {cards.map((card) =>
    card.href && card.status !== 'coming-soon' ? (
      <a class="card" href={card.href}>
        <div class="card__meta">
          <span>{card.icon ?? '◆'}</span>
          {card.audience && <span>{card.audience}</span>}
          {card.spoilerLevel && <span>{card.spoilerLevel}</span>}
        </div>
        <h3>{card.title}</h3>
        <p>{card.summary}</p>
        {card.helperText && <p class="card__helper">{card.helperText}</p>}
      </a>
    ) : (
      <article class="card card--disabled" aria-disabled="true">
        <div class="card__meta">
          <span>{card.icon ?? '◆'}</span>
          {card.audience && <span>{card.audience}</span>}
          {card.spoilerLevel && <span>{card.spoilerLevel}</span>}
          <span>Coming Soon</span>
        </div>
        <h3>{card.title}</h3>
        <p>{card.summary}</p>
        {card.helperText && <p class="card__helper">{card.helperText}</p>}
      </article>
    ),
  )}
</div>
