---
import { getCollection } from 'astro:content';
import CardGrid from '../components/CardGrid.astro';
import QuoteCallout from '../components/QuoteCallout.astro';
import ContentLayout from '../layouts/ContentLayout.astro';

const archetypes = await getCollection('archetypes');
const featuredArchetypes = ['gunslinger', 'walker', 'singer', 'tech-knight']
  .map((slug) => archetypes.find((entry) => entry.data.slug === slug))
  .filter(Boolean);
---

<ContentLayout
  title="Ka-Tet: The Path of the Beam"
  summary="A fan-made tabletop RPG of gunslingers, haunted doors, dying worlds, psychic songs, and ka-tets bound by fate."
  eyebrow="Recovered field manual"
  audience="public"
  ctaPrimary={{ label: 'Join a Demo Game', href: '/join-a-game' }}
  ctaSecondary={{ label: 'Start Here', href: '/start-here' }}
>
  <section class="split">
    <div class="section content-prose">
      <p class="section-label">Why This Hits</p>
      <p class="content-lead">
        This is a weird-western RPG about fate, gun smoke, broken roads, haunted machines, and the
        stubborn choice to protect something in a world that keeps trying to come apart.
      </p>
      <p>
        At the table, players form a ka-tet bound by destiny. You move through Mid-World and
        stranger places beyond it, face gunfights and cosmic wrongness, and decide whether the
        Tower, the Beams, and the people caught between them are still worth saving.
      </p>
      <div class="button-row">
        <a class="button button--ghost" href="/pregens">Pick a Pre-Gen</a>
        <a class="button button--ghost" href="/downloads/player-quickstart.md">Read the Quickstart</a>
      </div>
    </div>
    <div class="section content-prose home-panel">
      <p class="section-label">At A Glance</p>
      <div class="check-list">
        <span>Weird western horror</span>
        <span>Player-safe lore</span>
        <span>Fast onboarding</span>
        <span>Ka-driven teamwork</span>
        <span>Guns, songs, doors</span>
        <span>Demo ready</span>
      </div>
      <div class="home-stat-grid">
        <article>
          <strong>5 min</strong>
          <p>to understand the premise</p>
        </article>
        <article>
          <strong>1 session</strong>
          <p>to feel the tone and rules</p>
        </article>
        <article>
          <strong>0 homework</strong>
          <p>required to join a one-shot</p>
        </article>
      </div>
      <p class="home-note">
        New players are welcome. No prior Dark Tower knowledge required.
      </p>
    </div>
  </section>

  <section class="section">
    <p class="section-label">Choose Your Door</p>
    <CardGrid
      cards={[
        {
          title: 'Start Here',
          summary: 'Learn the premise, the terms, and what play feels like in five minutes.',
          href: '/start-here',
          icon: '↗',
        },
        {
          title: 'Player Guide',
          summary: 'Get the rulebook-facing overview for character creation, archetypes, and core play.',
          href: '/player-guide',
          icon: '✦',
        },
        {
          title: 'Campaigns',
          summary: 'Browse the player-safe pitch for Johnny Minor and future campaign arcs.',
          href: '/campaigns',
          icon: '☍',
        },
        {
          title: 'Downloads',
          summary: 'Grab quickstarts, pregens, and cheat sheets built for public and player-safe use.',
          href: '/downloads',
          icon: '⬇',
        },
      ]}
    />
  </section>

  <section class="split">
    <div class="section content-prose">
      <p class="section-label">What A Session Feels Like</p>
      <h2>Dust, dread, loyalty, and a few moments that feel bigger than luck.</h2>
      <ul>
        <li>A tense arrival in a town that already sounds half-broken</li>
        <li>Quiet campfire truth that changes the next fight completely</li>
        <li>Violence that is fast, loud, and rarely clean</li>
        <li>A dream, omen, or thinny that makes the road feel sentient</li>
        <li>Hard choices about mercy, duty, hunger, power, and fate</li>
      </ul>
    </div>
    <div class="section content-prose">
      <p class="section-label">What Makes It Distinct</p>
      <h2>Not just fantasy with revolvers.</h2>
      <ul>
        <li>Ka Points make destiny playable without drowning the game in metacurrency.</li>
        <li>The road matters as much as the fight: travel, weather, hunger, and strange geography all shape play.</li>
        <li>Magic feels haunted, rare, and costly instead of bright and routine.</li>
        <li>The setting supports both public demos and longer campaign arcs without forcing lore homework.</li>
      </ul>
      <div class="tag-list">
        <span>ka</span>
        <span>the beams</span>
        <span>mid-world</span>
        <span>thinnies</span>
        <span>gunslingers</span>
        <span>the white</span>
      </div>
    </div>
  </section>

  <section class="section content-prose">
    <p class="section-label">Best First Path</p>
    <div class="home-steps">
      <article>
        <span>01</span>
        <h3>Read The Premise</h3>
        <p>Start with the public-facing overview if you want the tone before the rules.</p>
        <a href="/start-here">Open Start Here</a>
      </article>
      <article>
        <span>02</span>
        <h3>Choose A Character</h3>
        <p>Either build from scratch or grab a pre-generated character and get moving fast.</p>
        <a href="/pregens">Browse Pregens</a>
      </article>
      <article>
        <span>03</span>
        <h3>Learn The Hooks</h3>
        <p>Skim Ka Points, firearms, and the basics of travel so the first session lands cleanly.</p>
        <a href="/player-guide">Enter The Player Guide</a>
      </article>
    </div>
  </section>

  <section class="split">
    <div class="section">
      <p class="section-label">Archetype Sampler</p>
      <CardGrid
        cards={featuredArchetypes.map((entry) => ({
          title: entry.data.title,
          summary: entry.data.summary,
          href: `/player-guide/archetypes/${entry.data.slug}/`,
          icon: entry.data.title[0],
          audience: 'player' as const,
          spoilerLevel: 'none' as const,
        }))}
      />
    </div>
    <div class="section content-prose">
      <p class="section-label">Looking For Players</p>
      <h2>Built for demo one-shots and future campaign groups.</h2>
      <p>
        This site is designed so someone can arrive cold, catch the vibe quickly, and still feel
        like they are stepping into a real setting instead of a generic starter page.
      </p>
      <p>
        If you want the tone first and the rules second, this is your door. If you want the full
        player-facing guide, that door is open too.
      </p>
      <p><strong>Next demo date:</strong> To be announced.</p>
    </div>
  </section>

  <QuoteCallout
    quote="Ka's not mercy, child. It's just motion. Like a wheel. Like a clock. Like a bullet."
    attribution="Johnny Minor"
    variant="beam"
  />

  <section class="section content-prose">
    <p class="section-label">Demo Friendly</p>
    <h2>New players can join with almost no prep.</h2>
    <p>
      The site is structured so someone can read the Start Here page, pick a pre-generated
      character, skim Ka Points, and sit down for a one-shot without needing deep lore homework.
    </p>
    <div class="button-row">
      <a class="button button--primary" href="/join-a-game">Join a Demo Game</a>
      <a class="button button--ghost" href="/demo">See How the One-Shot Works</a>
    </div>
  </section>
</ContentLayout>
