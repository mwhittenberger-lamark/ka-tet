---
import { getCollection } from 'astro:content';
import DownloadCard from '../components/DownloadCard.astro';
import ContentLayout from '../layouts/ContentLayout.astro';

const downloads = await getCollection('downloads');
const publicDownloads = downloads.filter((entry) => entry.data.audience !== 'gm');
const categories = [...new Set(publicDownloads.map((entry) => entry.data.category))];
---

<ContentLayout
  title="Downloads"
  summary="Quickstarts, character tools, and table-ready cheat sheets collected in one place."
  eyebrow="Download library"
  audience="public"
>
  <section class="section content-prose">
    <p>
      Everything linked on this page is public or player-safe. GM packets and spoiler-heavy tools
      live behind the GM gate.
    </p>
  </section>

  {categories.map((category) => (
    <section class="section">
      <p class="section-label">{category}</p>
      <div class="card-grid">
        {publicDownloads
          .filter((entry) => entry.data.category === category)
          .map((entry) => (
            <DownloadCard
              title={entry.data.title}
              summary={entry.data.summary}
              filePath={entry.data.file_path}
              fileType={entry.data.file_type}
              audience={entry.data.audience}
              spoilerLevel={entry.data.spoiler_level}
              available={Boolean(entry.data.file_path)}
            />
          ))}
      </div>
    </section>
  ))}
</ContentLayout>
