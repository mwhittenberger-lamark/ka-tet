---
import JoinInterestForm from '../components/JoinInterestForm.astro';
import ContentLayout from '../layouts/ContentLayout.astro';
---

<ContentLayout
  title="Join a Game"
  summary="Tell the GM what kind of Ka-Tet experience you want, what schedule works, and how horror-forward you want the table to be."
  eyebrow="Recruiting"
  audience="public"
>
  <section class="split">
    <div class="section content-prose">
      <p class="section-label">What Happens Next</p>
      <p>
        Use this form to join the interest list for future Ka-Tet demo games and campaigns. Once
        you send it, the message is forwarded to the site GM and stored in the form service inbox.
      </p>
      <p>
        Use the message field to call out schedule limits, favorite archetypes, or what kind of
        horror pacing works best for you.
      </p>
    </div>
    <div class="section content-prose">
      <p class="section-label">Tone Note</p>
      <p>
        Ka-Tet blends grief, dread, violence, and hope. The goal is not cruelty; it is emotionally
        resonant adventure with explicit safety tools and a collaborative table culture.
      </p>
      <p>
        If the form misbehaves, email <a class="kicker" href="mailto:mwhittenberger@lamarkmedia.com">mwhittenberger@lamarkmedia.com</a>.
      </p>
    </div>
  </section>

  <section class="section">
    <JoinInterestForm />
  </section>
</ContentLayout>
